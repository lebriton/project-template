#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

check() {
    if command -v "$1" &>/dev/null; then
        version=$("$1" --version 2>/dev/null | head -1 || echo "inconnu")
        echo -e "  ${GREEN}✓${NC} $1 (${version})"
    else
        echo -e "  ${RED}✗${NC} $1 — non trouvé"
        return 1
    fi
}

echo "Vérification des prérequis Gaia"
echo ""

ok=0
check toolA || ok=1
check toolB || ok=1
check toolC || ok=1

echo ""
if [ "$ok" -eq 0 ]; then
    echo -e "${GREEN}Tous les prérequis sont satisfaits.${NC}"
else
    echo -e "${RED}Certains prérequis sont manquants.${NC}"
    exit 1
fi
